# ============================================================================
# Bid 4 Local — environment configuration
# Copy to `.env.local` (Next.js) and fill in real values. NEVER commit secrets.
# ============================================================================

# ---- Supabase (public — safe to expose to the browser) --------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---- Supabase (server-only — NEVER expose to the client) ------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Database URLs --------------------------------------------------------
# Pooled connection for app runtime (PgBouncer, port 6543).
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection for migrations (port 5432).
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Demo accounts (dev only) ---------------------------------------------
# When true, seeded demo logins are offered on the sign-in page.
NEXT_PUBLIC_ENABLE_DEMO_ACCOUNTS=false

# ---- OAuth (configure in Supabase dashboard; these are for reference) -----
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=

# ---- Payments (server-only) -----------------------------------------------
PAYMENT_PROVIDER=mock            # mock | razorpay | stripe
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
